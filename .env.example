# Clerk (frontend + backend auth for ML API)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ML backend (Node.js) — default port 3001
ML_BACKEND_PORT=3001
ML_BACKEND_URL=http://localhost:3001

# Persistent model weights cache (reused across restarts)
# ML_MODEL_CACHE_DIR=/var/cache/snapid/models

# Frontend — enable cloud backend when signed in (set false for browser-only always)
VITE_USE_ML_BACKEND=true
VITE_ML_API_URL=/api

# Skip model warmup on backend startup
# ML_WARMUP=false
