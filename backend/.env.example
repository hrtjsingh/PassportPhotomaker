# Backend-only overrides (optional — repo root `.env` is loaded too)

# Clerk — required for protected ML API routes
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Server
ML_BACKEND_PORT=3001

# Persistent model cache (downloaded once, reused on restart)
# ML_MODEL_CACHE_DIR=../.cache/ml-models

# Skip model load on startup
# ML_WARMUP=false
